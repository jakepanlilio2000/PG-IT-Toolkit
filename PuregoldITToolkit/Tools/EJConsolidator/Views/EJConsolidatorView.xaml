<UserControl x:Class="PuregoldITToolkit.Tools.EJConsolidator.Views.EJConsolidatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SegmentedTab" TargetType="RadioButton">
            <Setter Property="Background" Value="#2F3640"/>
            <Setter Property="Foreground" Value="#7F8FA6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,0,5,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#353B48"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#0097E6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#F5F6FA"/>
            <Setter Property="Foreground" Value="#2F3640"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E1B12C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#E1B12C"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#0097E6"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#0097E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton Content="Standard Consolidator" IsChecked="{Binding IsModeConsolidator}" Style="{StaticResource SegmentedTab}"/>
            <RadioButton Content="Transaction Finder" IsChecked="{Binding IsModeTrxFinder}" Style="{StaticResource SegmentedTab}"/>
        </StackPanel>

        <!-- CONFIGURATION -->
        <StackPanel Grid.Row="2">
            <WrapPanel Margin="0,0,0,15">
                <TextBlock Text="Store Code:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Text="{Binding StoreCode, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="5" Margin="0,0,20,0"/>

                <TextBlock Text="Date Range:" Width="90" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="120" Margin="0,0,10,0"/>
                <TextBlock Text="to" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="120"/>
            </WrapPanel>

            <WrapPanel Margin="0,0,0,15">
                <TextBlock Text="Live Server IP:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Text="{Binding LiveServerIp, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="5" Margin="0,0,20,0"/>

                <TextBlock Text="Total POS Lanes:" Width="110" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Text="{Binding TotalPosCount, UpdateSourceTrigger=PropertyChanged}" Width="50" Padding="5" Margin="0,0,20,0"/>
            </WrapPanel>

            <!-- Displayed Only in Finder Mode -->
            <StackPanel Margin="0,0,0,15" Visibility="{Binding IsModeTrxFinder, Converter={StaticResource BoolToVis}}">
                <WrapPanel>
                    <TextBlock Text="Transaction #:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding TargetTrxNumber, UpdateSourceTrigger=PropertyChanged}" Width="332" Padding="5"/>
                </WrapPanel>
                <TextBlock Text="* Exact transaction number. Extracted file will be renamed to [TrxNumber].txt." FontSize="11" FontStyle="Italic" Foreground="#7F8FA6" Margin="120,2,0,0"/>
            </StackPanel>

            <!-- Displayed Only in Consolidator Mode -->
            <StackPanel Margin="0,0,0,15" Visibility="{Binding IsModeConsolidator, Converter={StaticResource BoolToVis}}">
                <WrapPanel>
                    <TextBlock Text="Target Lanes:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding PosLanes, UpdateSourceTrigger=PropertyChanged}" Width="332" Padding="5"/>
                </WrapPanel>
                <TextBlock Text="* Leave blank to process ALL. Use commas for specifics (e.g. 1, 3, 10)." FontSize="11" FontStyle="Italic" Foreground="#7F8FA6" Margin="120,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- FILTERS (Consolidator Mode Only) -->
        <GroupBox Header="Extraction Filters &amp; Format" Grid.Row="3" Margin="0,10,0,20" Padding="15" BorderBrush="#DCDDE1" Visibility="{Binding IsModeConsolidator, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <WrapPanel Margin="0,0,0,10">
                    <ToggleButton Content="Second Receipt Only" IsChecked="{Binding SecondReceiptOnly}" Style="{StaticResource TileToggleStyle}" />
                    <ToggleButton Content="GCash Barcodes Only" IsChecked="{Binding GcashBarcodeOnly}" Style="{StaticResource TileToggleStyle}" />
                    <ToggleButton Content="HACS Online Only" IsChecked="{Binding HacsOnlineOnly}" Style="{StaticResource TileToggleStyle}" />
                    <ToggleButton Content="X-Read / Z-Read Only" IsChecked="{Binding XReadZReadOnly}" Style="{StaticResource TileToggleStyle}" />
                    <ToggleButton Content="Merge Output Into Single File" IsChecked="{Binding MergeAllIntoOneFile}" Style="{StaticResource TileToggleStyle}" />
                </WrapPanel>

                <WrapPanel Margin="0,5">
                    <TextBlock Text="Specific Cashier:" Width="110" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SpecificCashier}" Width="150" Padding="5" Margin="0,0,20,0"/>

                    <TextBlock Text="Specific Bagger:" Width="110" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SpecificBagger}" Width="150" Padding="5"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- ACTIONS & STATUS -->
        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="14" Margin="0,0,0,5" TextWrapping="Wrap"/>

            <ProgressBar Value="{Binding ProgressValue}" Height="6" Margin="0,0,0,10" Background="#DCDDE1" Foreground="#0097E6" BorderThickness="0" Maximum="100"/>

            <Button Command="{Binding ProcessCommand}" Content="EXECUTE EJ ENGINE" Height="45" FontSize="16" FontWeight="Bold" Background="#273C75" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>