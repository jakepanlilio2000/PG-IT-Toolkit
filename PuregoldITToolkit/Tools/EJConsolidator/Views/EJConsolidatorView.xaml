<UserControl x:Class="PuregoldITToolkit.Tools.EJConsolidator.Views.EJConsolidatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SegmentedTab" TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource BgApp}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,0,8,0" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHighlight}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHighlight}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryDark}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandAccent}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrandAccent}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryDark}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <RadioButton Content="Standard Consolidator" IsChecked="{Binding IsModeConsolidator}" Style="{StaticResource SegmentedTab}"/>
            <RadioButton Content="Transaction Finder" IsChecked="{Binding IsModeTrxFinder}" Style="{StaticResource SegmentedTab}"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Configuration" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15"/>

                    <WrapPanel Margin="0,0,0,12">
                        <TextBlock Text="Store Code:" Width="120" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding StoreCode, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="0,0,20,0"/>

                        <TextBlock Text="Date Range:" Width="100" Style="{StaticResource FormLabel}"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Width="130" Margin="0,0,10,0" Padding="5"/>
                        <TextBlock Text="to" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondary}"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Width="130" Padding="5"/>
                    </WrapPanel>

                    <WrapPanel Margin="0,0,0,12">
                        <TextBlock Text="Live Server IP:" Width="120" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding LiveServerIp, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="0,0,20,0"/>

                        <TextBlock Text="Total POS Lanes:" Width="120" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding TotalPosCount, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                    </WrapPanel>

                    <StackPanel Margin="0,12,0,0" Visibility="{Binding IsModeTrxFinder, Converter={StaticResource BoolToVis}}">
                        <WrapPanel>
                            <TextBlock Text="Transaction #:" Width="120" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding TargetTrxNumber, UpdateSourceTrigger=PropertyChanged}" Width="350"/>
                        </WrapPanel>
                        <TextBlock Text="* Exact transaction number. Extracted file will be renamed to [TrxNumber].txt." FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="130,5,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,12,0,0" Visibility="{Binding IsModeConsolidator, Converter={StaticResource BoolToVis}}">
                        <WrapPanel>
                            <TextBlock Text="Target Lanes:" Width="120" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding PosLanes, UpdateSourceTrigger=PropertyChanged}" Width="350"/>
                        </WrapPanel>
                        <TextBlock Text="* Leave blank to process ALL. Use commas for specifics (e.g. 1, 3, 10)." FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="130,5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Visibility="{Binding IsModeConsolidator, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Extraction Filters &amp; Format" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15"/>

                
                <WrapPanel Margin="0,0,0,15">
                    <ToggleButton Content="Second Receipt Only" IsChecked="{Binding SecondReceiptOnly}" Style="{StaticResource TileToggleStyle}" />
                    <ToggleButton Content="GCash Barcodes Only" IsChecked="{Binding GcashBarcodeOnly}" Style="{StaticResource TileToggleStyle}" />
                    <ToggleButton Content="HACS Online Only" IsChecked="{Binding HacsOnlineOnly}" Style="{StaticResource TileToggleStyle}" />
                    <ToggleButton Content="X-Read / Z-Read Only" IsChecked="{Binding XReadZReadOnly}" Style="{StaticResource TileToggleStyle}" />
                    <ToggleButton Content="Merge Output Into Single File" IsChecked="{Binding MergeAllIntoOneFile}" Style="{StaticResource TileToggleStyle}" />
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Text="Card (Last 4):" Width="120" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FilterCardLast4}" Width="80" Margin="0,0,25,0"/>

                    <TextBlock Text="Member Name:" Width="120" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FilterMemberName}" Width="160" Margin="0,0,25,0"/>

                    <TextBlock Text="Exact Amount:" Width="120" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding FilterExactAmount}" Width="160"/>
                </WrapPanel>

                <WrapPanel Margin="0,5">
                    <TextBlock Text="Specific Cashier:" Width="120" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding SpecificCashier}" Width="160" Margin="0,0,25,0"/>

                    <TextBlock Text="Specific Bagger:" Width="120" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding SpecificBagger}" Width="160"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <ProgressBar Value="{Binding ProgressValue}" Height="8" Margin="0,0,0,15" Background="{StaticResource BorderLight}" Foreground="{StaticResource BrandPrimary}" BorderThickness="0" Maximum="100"/>

            <Button Command="{Binding ProcessCommand}" Content="EXECUTE EJ ENGINE" Height="55" FontSize="16" Style="{StaticResource DangerButton}"/>
        </StackPanel>
    </Grid>
</UserControl>