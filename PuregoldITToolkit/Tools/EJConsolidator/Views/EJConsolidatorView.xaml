<UserControl x:Class="PuregoldITToolkit.Tools.EJConsolidator.Views.EJConsolidatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SegmentedTab" TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource BgApp}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,0,8,0" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHighlight}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHighlight}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryDark}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandAccent}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrandAccent}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandPrimaryDark}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <StackPanel>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="1. Target Source &amp; Network" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" VerticalAlignment="Center"/>
                            <Border Background="{StaticResource BtnSuccess}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right">
                                <TextBlock Text="🌐 Linked to Global Settings" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                            </Border>
                        </Grid>

                        <WrapPanel Margin="0,0,0,12">
                            <StackPanel Margin="0,0,25,0" Width="120">
                                <TextBlock Text="Store Code" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding StoreCode, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,25,0" Width="120">
                                <TextBlock Text="Total POS Lanes" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding TotalPosCount, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Search Date Range" Style="{StaticResource FormLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <DatePicker SelectedDate="{Binding StartDate}" Width="140" Margin="0,0,10,0" Padding="5"/>
                                    <TextBlock Text="to" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondary}"/>
                                    <DatePicker SelectedDate="{Binding EndDate}" Width="140" Padding="5"/>
                                </StackPanel>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="2. Operation Mode" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <RadioButton Content="🗂️ Standard Consolidator (Batch)" IsChecked="{Binding IsModeConsolidator}" Style="{StaticResource SegmentedTab}"/>
                            <RadioButton Content="🔍 Transaction Finder (Exact)" IsChecked="{Binding IsModeTrxFinder}" Style="{StaticResource SegmentedTab}"/>
                        </StackPanel>

                        <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Visibility="{Binding IsModeConsolidator, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <WrapPanel>
                                    <TextBlock Text="Target Lanes:" Width="90" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding PosLanes, UpdateSourceTrigger=PropertyChanged}" Width="350"/>
                                </WrapPanel>
                                <TextBlock Text="* Leave blank to merge ALL lanes. Use commas for specific POS (e.g., 1, 3, 10)." FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="90,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Visibility="{Binding IsModeTrxFinder, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <WrapPanel>
                                    <TextBlock Text="Transaction #:" Width="90" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding TargetTrxNumber, UpdateSourceTrigger=PropertyChanged}" Width="350"/>
                                </WrapPanel>
                                <TextBlock Text="* Requires the exact receipt transaction number. Extracted output will be named [TrxNumber].txt." FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="90,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Visibility="{Binding IsModeConsolidator, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="3. Smart Content Filters" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15"/>

                        <TextBlock Text="Quick Receipt Type Toggles" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="12"/>
                        <WrapPanel Margin="0,0,0,15">
                            <ToggleButton Content="Second Receipt Only" IsChecked="{Binding SecondReceiptOnly}" Style="{StaticResource TileToggleStyle}" />
                            <ToggleButton Content="GCash Barcodes Only" IsChecked="{Binding GcashBarcodeOnly}" Style="{StaticResource TileToggleStyle}" />
                            <ToggleButton Content="HACS Online Only" IsChecked="{Binding HacsOnlineOnly}" Style="{StaticResource TileToggleStyle}" />
                            <ToggleButton Content="X-Read / Z-Read Only" IsChecked="{Binding XReadZReadOnly}" Style="{StaticResource TileToggleStyle}" />
                            <ToggleButton Content="Combine Output into Single File" IsChecked="{Binding MergeAllIntoOneFile}" Style="{StaticResource TileToggleStyle}" />
                        </WrapPanel>

                        <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Staff Identity" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="12"/>
                                <WrapPanel Margin="0,0,0,15">
                                    <StackPanel Margin="0,0,25,0" Width="180">
                                        <TextBlock Text="Specific Cashier" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding SpecificCashier}"/>
                                    </StackPanel>
                                    <StackPanel Width="180">
                                        <TextBlock Text="Specific Bagger" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding SpecificBagger}"/>
                                    </StackPanel>
                                </WrapPanel>

                                <TextBlock Text="Receipt Data Content" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="12"/>
                                <WrapPanel>
                                    <StackPanel Margin="0,0,20,12" Width="140">
                                        <TextBlock Text="Exact Total Amount" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding FilterExactAmount}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,12" Width="200">
                                        <TextBlock Text="Member Name" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding FilterMemberName}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,12" Width="120">
                                        <TextBlock Text="Card (Last 4)" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding FilterCardLast4}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12" Width="220">
                                        <TextBlock Text="SKU / UPC / Item Name" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding FilterProductOrSku}"/>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>
            <ProgressBar Value="{Binding ProgressValue}" Height="8" Margin="0,0,0,15" Background="{StaticResource BorderLight}" Foreground="{StaticResource BrandPrimary}" BorderThickness="0" Maximum="100"/>
            <Button Command="{Binding ProcessCommand}" Content="⚡ EXECUTE EJ EXTRACTION" Height="55" FontSize="16" Style="{StaticResource DangerButton}"/>
        </StackPanel>
    </Grid>
</UserControl>