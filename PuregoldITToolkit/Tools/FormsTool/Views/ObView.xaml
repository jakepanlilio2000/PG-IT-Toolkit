<UserControl x:Class="PuregoldITToolkit.Tools.FormsTool.Views.ObView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Official Business (OB) Form Generator" FontSize="24" FontWeight="Light" Foreground="#2F3640" Margin="0,0,0,15"/>

        <!-- LEFT COLUMN: Form Entry -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
            <StackPanel>

                <!-- INSTRUCTIONS PANEL -->
                <Border Background="#E8F4F8" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Instructions:" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,5"/>
                        <TextBlock Text="1. Fill out all required fields. Name and Position will auto-capitalize.&#x0a;2. You can type a signature OR upload a transparent PNG image.&#x0a;3. Click Generate to create and auto-open the stamped image template." TextWrapping="Wrap" Foreground="#2C3E50" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <!-- DATA ENTRY FORM -->
                <Border Background="#F5F6FA" CornerRadius="6" Padding="25" BorderBrush="#DCDDE1" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Required Fields" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#2C3E50"/>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Employee Name *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.EmployeeName, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Position *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.Position, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Department *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.Department, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                        </StackPanel>

                        <TextBlock Text="Trip Details &amp; Options" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#2C3E50"/>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="OB Schedule (Date &amp; Time)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.ObSchedule, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                        </StackPanel>
                        <WrapPanel>
                            <StackPanel Margin="0,0,20,15" Width="150">
                                <TextBlock Text="Date Filed (Optional)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding FormData.DateFiled}" Padding="5" FontSize="14" Height="34"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,15" Width="180">
                                <TextBlock Text="Typed Signature" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.EmployeeSignature, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                            </StackPanel>
                            <TextBlock Text="- OR -" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" Foreground="#7F8FA6"/>
                            <StackPanel Margin="0,0,0,15" Width="150">
                                <TextBlock Text="Upload PNG Signature" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <Button Command="{Binding BrowseSignatureCommand}" Content="Browse PNG..." Padding="5" Height="34" Background="#E1B12C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </WrapPanel>
                        <TextBlock Text="{Binding FormData.SignatureImagePath, StringFormat='Attached: {0}'}" FontSize="11" Foreground="#27ae60" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT COLUMN: Live Image Preview -->
        <Border Grid.Row="1" Grid.Column="1" Background="#ECF0F1" BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Live Preview" FontWeight="Bold" Foreground="#7F8FA6" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <!-- FIX: Bind to LivePreviewImage instead of OutputImagePath -->
                <Image Source="{Binding LivePreviewImage}" Stretch="Uniform" MaxHeight="450" RenderOptions.BitmapScalingMode="HighQuality"/>

                <TextBlock Text="Start typing to see live preview" Foreground="#BDC3C7" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <!-- FIX: Trigger on LivePreviewImage -->
                                <DataTrigger Binding="{Binding LivePreviewImage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- FOOTER / EXPORT -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#2980B9" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Command="{Binding ExportCommand}" Content="GENERATE OB IMAGE" HorizontalAlignment="Right" Background="#273C75" Foreground="White" FontWeight="Bold" Padding="25,10" BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</UserControl>