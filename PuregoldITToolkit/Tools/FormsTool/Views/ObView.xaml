<UserControl x:Class="PuregoldITToolkit.Tools.FormsTool.Views.ObView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
            <StackPanel>
                <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Instructions:" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,8"/>
                        <TextBlock Text="1. Fill out all required fields. Name and Position will auto-capitalize.&#x0a;2. You can type a signature OR upload a transparent PNG image.&#x0a;3. Click Generate to create and auto-open the stamped image template." TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Required Fields" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Employee Name *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormData.EmployeeName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Position *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormData.Position, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Department *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormData.Department, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <TextBlock Text="Trip Details &amp; Options" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="OB Schedule (Date &amp; Time)" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormData.ObSchedule, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <WrapPanel>
                            <StackPanel Margin="0,0,20,15" Width="160">
                                <TextBlock Text="Date Filed (Optional)" Style="{StaticResource FormLabel}"/>
                                <DatePicker SelectedDate="{Binding FormData.DateFiled}" Height="34" Padding="5"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,10,15" Width="190">
                                <TextBlock Text="Typed Signature" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.EmployeeSignature, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <TextBlock Text="- OR -" VerticalAlignment="Center" Margin="0,0,10,15" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>

                            <StackPanel Margin="0,0,0,15" Width="160">
                                <TextBlock Text="Upload PNG Signature" Style="{StaticResource FormLabel}"/>
                                <Button Command="{Binding BrowseSignatureCommand}" Content="Browse PNG..." Background="{StaticResource BrandAccent}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </WrapPanel>

                        <TextBlock Text="{Binding FormData.SignatureImagePath, StringFormat='Attached: {0}'}" FontSize="11" Foreground="{StaticResource BtnSuccess}" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Live Preview" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <Image Source="{Binding LivePreviewImage}" Stretch="Uniform" MaxHeight="450" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Start typing to see live preview" Foreground="{StaticResource TextSecondary}" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LivePreviewImage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrandPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Command="{Binding ExportCommand}" Content="GENERATE OB IMAGE" Style="{StaticResource DangerButton}" Padding="30,12" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</UserControl>