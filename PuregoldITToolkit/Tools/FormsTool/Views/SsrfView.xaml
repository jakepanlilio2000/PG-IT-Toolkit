<UserControl x:Class="PuregoldITToolkit.Tools.FormsTool.Views.SsrfView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="SSRF Batch Printing Engine" FontWeight="Bold" FontSize="18" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0" Padding="0,0,10,0">
            <StackPanel HorizontalAlignment="Left" MaxWidth="600">

                <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Instructions:" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,8"/>
                        <TextBlock Text="1. Enter any base details you want pre-printed (Location, Dept, Date are optional).&#x0a;2. Provide the starting SSRF Number (e.g. 722-0001).&#x0a;3. Set the quantity. The printer will automatically increment the number for each page!" TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Document Base Details (Optional)" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="{StaticResource BrandPrimary}"/>

                        <WrapPanel Margin="0,0,0,10">
                            <StackPanel Margin="0,0,20,15" Width="260">
                                <TextBlock Text="Location / Store" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.Location, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,15" Width="160">
                                <TextBlock Text="Department" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.Department, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </WrapPanel>

                        <WrapPanel>
                            <StackPanel Margin="0,0,20,0" Width="210">
                                <TextBlock Text="Date Filed" Style="{StaticResource FormLabel}"/>
                                <DatePicker SelectedDate="{Binding FormData.DateFiled}" Height="34" Padding="5"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BgApp}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Auto-Increment Print Job Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>

                        <WrapPanel>
                            <StackPanel Margin="0,0,20,0" Width="210">
                                <TextBlock Text="Starting SSRF #" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.BaseSsrfNumber, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Width="160">
                                <TextBlock Text="Copies to Print" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.PrintQuantity, UpdateSourceTrigger=PropertyChanged}" FontSize="16" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </WrapPanel>

                        <TextBlock Text="* Please ensure paper tray is loaded before starting job." FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="0,15,0,0" FontSize="11"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Preview Pane -->
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="Live Print Preview" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <Image Source="{Binding LivePreviewImage}" Stretch="Uniform" MaxHeight="600" RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>
        </Border>

        <!-- Execution -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrandPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Command="{Binding PrintCommand}" Content="🖨️ START BATCH PRINT JOB" FontSize="14" Style="{StaticResource DangerButton}" Padding="30,15" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</UserControl>