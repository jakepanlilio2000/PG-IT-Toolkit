<UserControl x:Class="PuregoldITToolkit.Tools.FormsTool.Views.SsrfView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Split Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="System Service Request (SSRF) Batch Printer" FontSize="24" FontWeight="Light" Foreground="#2F3640" Margin="0,0,0,15"/>

        <!-- LEFT COLUMN: Form Entry -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
            <StackPanel HorizontalAlignment="Left" MaxWidth="600">

                <Border Background="#E8F4F8" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Instructions:" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,5"/>
                        <TextBlock Text="1. Enter any base details you want pre-printed (Location, Dept, Date are optional).&#x0a;2. Provide the starting SSRF Number (e.g. 722-0001).&#x0a;3. Set the quantity. The printer will automatically increment the number for each page!" TextWrapping="Wrap" Foreground="#2C3E50" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <Border Background="#F5F6FA" CornerRadius="6" Padding="25" BorderBrush="#DCDDE1" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Document Base Details (Optional)" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#2C3E50"/>

                        <WrapPanel Margin="0,0,0,10">
                            <StackPanel Margin="0,0,20,15" Width="250">
                                <TextBlock Text="Location" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.Location, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,15" Width="150">
                                <TextBlock Text="Department" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.Department, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="14"/>
                            </StackPanel>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,15">
                            <StackPanel Margin="0,0,20,15" Width="200">
                                <TextBlock Text="Date Filed" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding FormData.DateFiled}" Padding="5" FontSize="14" Height="34"/>
                            </StackPanel>
                        </WrapPanel>

                        <Border Background="#FFF2CC" BorderBrush="#F1C40F" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Auto-Increment Print Job" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#D35400"/>

                                <WrapPanel>
                                    <StackPanel Margin="0,0,20,0" Width="200">
                                        <TextBlock Text="Starting SSRF #" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding FormData.BaseSsrfNumber, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="16" FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Width="150">
                                        <TextBlock Text="Copies to Print" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding FormData.PrintQuantity, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="16" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                </WrapPanel>
                                <TextBlock Text="* Please ensure paper tray is loaded before starting job." FontStyle="Italic" Foreground="#D35400" Margin="0,15,0,0" FontSize="11"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT COLUMN: Live Image Preview -->
        <Border Grid.Row="1" Grid.Column="1" Background="#ECF0F1" BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="Live Print Preview" FontWeight="Bold" Foreground="#7F8FA6" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <Image Source="{Binding LivePreviewImage}" Stretch="Uniform" MaxHeight="600" RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>
        </Border>

        <!-- FOOTER / EXPORT -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#2980B9" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Command="{Binding PrintCommand}" Content="START BATCH PRINT JOB" HorizontalAlignment="Right" Background="#273C75" Foreground="White" FontWeight="Bold" Padding="25,10" BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</UserControl>