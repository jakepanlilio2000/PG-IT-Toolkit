<UserControl x:Class="PuregoldITToolkit.Tools.FormsTool.Views.TsrfView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55*"/>
            <ColumnDefinition Width="45*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Technical Service Request (TSRF) Generator" FontSize="24" FontWeight="Light" Foreground="#2F3640" Margin="0,0,0,15"/>

        <!-- LEFT COLUMN: Form Entry -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
            <StackPanel>

                <!-- INSTRUCTIONS PANEL -->
                <Border Background="#E8F4F8" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Instructions:" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,5"/>
                        <TextBlock Text="1. Start typing to see your data instantly appear on the Live Preview to the right.&#x0a;2. All names and positions are automatically capitalized and centered.&#x0a;3. Click Generate to save the final official copy to your desktop." TextWrapping="Wrap" Foreground="#2C3E50" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <Border Background="#F5F6FA" CornerRadius="6" Padding="25" BorderBrush="#DCDDE1" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Document Meta" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="#2C3E50"/>
                        <WrapPanel Margin="0,0,0,15">
                            <StackPanel Margin="0,0,15,10">
                                <TextBlock Text="Company *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.Company, UpdateSourceTrigger=PropertyChanged}" Width="250" Padding="8"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,10">
                                <TextBlock Text="Others (Store) *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.Others, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,10">
                                <TextBlock Text="Requesting Dept." FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.RequestingDept, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,10">
                                <TextBlock Text="TSRF Number" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.TsrfNumber, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="8"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,10">
                                <TextBlock Text="Date" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding FormData.DateFiled}" Width="120" Height="33"/>
                            </StackPanel>
                        </WrapPanel>

                        <TextBlock Text="Technical Details" FontWeight="Bold" FontSize="16" Margin="0,10,0,10" Foreground="#2C3E50"/>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Asset Description *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.AssetDescription, UpdateSourceTrigger=PropertyChanged}" Padding="8" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Problem Details *" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.ProblemDetails, UpdateSourceTrigger=PropertyChanged}" Padding="8" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Action Taken" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.ActionTaken, UpdateSourceTrigger=PropertyChanged}" Padding="8" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Remarks" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FormData.Remarks, UpdateSourceTrigger=PropertyChanged}" Padding="8" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>

                        <TextBlock Text="Action Signatories" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="#2C3E50"/>
                        <WrapPanel Margin="0,0,0,15">
                            <StackPanel Margin="0,0,15,15">
                                <TextBlock Text="Requester Name" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.RequesterName, UpdateSourceTrigger=PropertyChanged}" Width="180" Padding="8"/>
                                <TextBox Text="{Binding FormData.RequesterPosition, UpdateSourceTrigger=PropertyChanged}" Width="180" Padding="8" Margin="0,5,0,0" Foreground="#7F8FA6" ToolTip="Position"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,15">
                                <TextBlock Text="Performed By Name" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.PerformedByName, UpdateSourceTrigger=PropertyChanged}" Width="180" Padding="8"/>
                                <TextBox Text="{Binding FormData.PerformedByPosition, UpdateSourceTrigger=PropertyChanged}" Width="180" Padding="8" Margin="0,5,0,0" Foreground="#7F8FA6" ToolTip="Position"/>
                            </StackPanel>
                        </WrapPanel>

                        <TextBlock Text="Noted By Signatories" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="#2C3E50"/>
                        <WrapPanel>
                            <!-- 2 Dept Heads -->
                            <StackPanel Margin="0,0,15,15">
                                <TextBlock Text="Dept Head (1)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.NotedByDeptHead1, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8"/>
                                <TextBox Text="{Binding FormData.NotedByDeptHead1Pos, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8" Margin="0,5,0,0" Foreground="#7F8FA6"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,25,15">
                                <TextBlock Text="Dept Head (2)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.NotedByDeptHead2, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8"/>
                                <TextBox Text="{Binding FormData.NotedByDeptHead2Pos, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8" Margin="0,5,0,0" Foreground="#7F8FA6"/>
                            </StackPanel>

                            <!-- 2 MIS Heads -->
                            <StackPanel Margin="0,0,15,15">
                                <TextBlock Text="MIS Head (1)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.NotedByMis1, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8"/>
                                <TextBox Text="{Binding FormData.NotedByMis1Pos, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8" Margin="0,5,0,0" Foreground="#7F8FA6"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="MIS Head (2)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FormData.NotedByMis2, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8"/>
                                <TextBox Text="{Binding FormData.NotedByMis2Pos, UpdateSourceTrigger=PropertyChanged}" Width="150" Padding="8" Margin="0,5,0,0" Foreground="#7F8FA6"/>
                            </StackPanel>
                        </WrapPanel>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT COLUMN: Live Image Preview -->
        <Border Grid.Row="1" Grid.Column="1" Background="#ECF0F1" BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="6" Padding="10">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="Live Preview" FontWeight="Bold" Foreground="#7F8FA6" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <!-- Real-Time In-Memory Binding -->
                <Image Source="{Binding LivePreviewImage}" Stretch="Uniform" MaxHeight="600" RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>
        </Border>

        <!-- FOOTER / EXPORT -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#2980B9" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Command="{Binding ExportCommand}" Content="SAVE FINAL TSRF" HorizontalAlignment="Right" Background="#273C75" Foreground="White" FontWeight="Bold" Padding="25,10" BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</UserControl>