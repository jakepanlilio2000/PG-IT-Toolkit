<UserControl x:Class="PuregoldITToolkit.Tools.FormsTool.Views.TsrfView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55*"/>
            <ColumnDefinition Width="45*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
            <StackPanel>
                <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Instructions:" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,8"/>
                        <TextBlock Text="1. Start typing to see your data instantly appear on the Live Preview to the right.&#x0a;2. All names and positions are automatically capitalized and centered.&#x0a;3. Click Generate to save the final official copy to your desktop." TextWrapping="Wrap" Foreground="{StaticResource TextPrimary}" LineHeight="20"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Document Meta" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>

                        <WrapPanel Margin="0,0,0,20">
                            <StackPanel Margin="0,0,15,12" Width="260">
                                <TextBlock Text="Company *" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.Company, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="160">
                                <TextBlock Text="Others (Store) *" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.Others, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="160">
                                <TextBlock Text="Requesting Dept." Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.RequestingDept, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="130">
                                <TextBlock Text="TSRF Number" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.TsrfNumber, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="130">
                                <TextBlock Text="Date" Style="{StaticResource FormLabel}"/>
                                <DatePicker SelectedDate="{Binding FormData.DateFiled}" Height="34" Padding="5"/>
                            </StackPanel>
                        </WrapPanel>

                        <TextBlock Text="Technical Details" FontWeight="Bold" FontSize="16" Margin="0,10,0,15" Foreground="{StaticResource TextPrimary}"/>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Asset Description *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormData.AssetDescription, UpdateSourceTrigger=PropertyChanged}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Problem Details *" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormData.ProblemDetails, UpdateSourceTrigger=PropertyChanged}" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Action Taken" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormData.ActionTaken, UpdateSourceTrigger=PropertyChanged}" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,25">
                            <TextBlock Text="Remarks" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding FormData.Remarks, UpdateSourceTrigger=PropertyChanged}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>

                        <TextBlock Text="Action Signatories" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>

                        <WrapPanel Margin="0,0,0,20">
                            <StackPanel Margin="0,0,20,15" Width="190">
                                <TextBlock Text="Requester Name" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.RequesterName, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Text="{Binding FormData.RequesterPosition, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" ToolTip="Position"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,15" Width="190">
                                <TextBlock Text="Performed By Name" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.PerformedByName, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Text="{Binding FormData.PerformedByPosition, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}" ToolTip="Position"/>
                            </StackPanel>
                        </WrapPanel>

                        <TextBlock Text="Noted By Signatories" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>

                        <WrapPanel>
                            <StackPanel Margin="0,0,15,15" Width="160">
                                <TextBlock Text="Dept Head (1)" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.NotedByDeptHead1, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Text="{Binding FormData.NotedByDeptHead1Pos, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,25,15" Width="160">
                                <TextBlock Text="Dept Head (2)" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.NotedByDeptHead2, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Text="{Binding FormData.NotedByDeptHead2Pos, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,15,15" Width="160">
                                <TextBlock Text="MIS Head (1)" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.NotedByMis1, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Text="{Binding FormData.NotedByMis1Pos, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,15" Width="160">
                                <TextBlock Text="MIS Head (2)" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding FormData.NotedByMis2, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Text="{Binding FormData.NotedByMis2Pos, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="Live Preview" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <Image Source="{Binding LivePreviewImage}" Stretch="Uniform" MaxHeight="600" RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrandPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Command="{Binding ExportCommand}" Content="SAVE FINAL TSRF" Style="{StaticResource DangerButton}" Padding="30,12" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</UserControl>