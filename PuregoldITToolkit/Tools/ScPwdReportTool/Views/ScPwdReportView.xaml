<UserControl x:Class="PuregoldITToolkit.Tools.ScPwdReportTool.Views.ScPwdReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PuregoldITToolkit.Core.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <StackPanel>
                <!-- Target Source -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="1. Target Source &amp; Network" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15"/>
                        <WrapPanel Margin="0,0,0,15">
                            <StackPanel Margin="0,0,25,0" Width="100">
                                <TextBlock Text="Store Code" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding StoreCode, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,25,0" Width="250">
                                <TextBlock Text="Store Name / Description" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding StoreName, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,25,0" Width="150">
                                <TextBlock Text="Live Server IP" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding LiveServerIp, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>
                            </StackPanel>
                        </WrapPanel>
                        <WrapPanel>
                            <StackPanel Margin="0,0,25,0">
                                <TextBlock Text="Search Date Range" Style="{StaticResource FormLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <DatePicker SelectedDate="{Binding StartDate}" Width="140" Margin="0,0,10,0" Padding="5"/>
                                    <TextBlock Text="to" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondary}"/>
                                    <DatePicker SelectedDate="{Binding EndDate}" Width="140" Padding="5"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Target Lanes (Blank for All)" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding PosLanes, UpdateSourceTrigger=PropertyChanged}" Width="250" FontSize="14" Tag="e.g. 1, 2, 5"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Generation Settings -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="2. Export &amp; Formatting Configurations" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15"/>
                        <WrapPanel Margin="0,0,0,20">
                            <CheckBox Content="Generate Senior Citizen (SC) Report" IsChecked="{Binding GenerateScReport}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Margin="0,0,25,0"/>
                            <CheckBox Content="Generate PWD Report" IsChecked="{Binding GeneratePwdReport}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Margin="0,0,25,0"/>
                        </WrapPanel>
                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,40,0">
                                <TextBlock Text="Export Date Partition (Chunk Size):" Style="{StaticResource FormLabel}" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding ReportChunkDays, UpdateSourceTrigger=PropertyChanged}" Width="50" TextAlignment="Center" FontWeight="Bold"/>
                                <TextBlock Text="Days per .xls file" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="User ID (For Excel Header):" Style="{StaticResource FormLabel}" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding ReportUserId, UpdateSourceTrigger=PropertyChanged}" Width="120" TextAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Execution Panel -->
        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>
            <ProgressBar Value="{Binding ProgressValue}" Height="8" Margin="0,0,0,15" Background="{StaticResource BorderLight}" Foreground="{StaticResource BrandPrimary}" BorderThickness="0" Maximum="100"/>
            <Button Command="{Binding ProcessCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="⚡ GENERATE EXCEL REPORTS" Height="55" FontSize="16" Style="{StaticResource DangerButton}"/>
        </StackPanel>
    </Grid>
</UserControl>