<UserControl x:Class="PuregoldITToolkit.Tools.SodChecker.Views.SodCheckerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PuregoldITToolkit.Core.Converters"
             xmlns:models="clr-namespace:PuregoldITToolkit.Tools.SodChecker.Models">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        
        <Style x:Key="SegmentedTab" TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource BgApp}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}" 
                                CornerRadius="4" 
                                Margin="0,0,8,0"
                                BorderBrush="{StaticResource BorderLight}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHighlight}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="StatusCellTemplate" DataType="{x:Type models:FileCheckStatus}">
            <Border x:Name="BgBorder" CornerRadius="4" Padding="6" Margin="2">
                <StackPanel>
                    <TextBlock x:Name="TxtStatus" Text="NO" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock x:Name="TxtMeta" Text="{Binding FormattedSize}" Foreground="#E0E0E0" HorizontalAlignment="Center" FontSize="9" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Missing">
                    <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource BtnDanger}"/>
                    <Setter TargetName="TxtStatus" Property="Text" Value="NO"/>
                    <Setter TargetName="TxtMeta" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Ok">
                    <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource BtnSuccess}"/>
                    <Setter TargetName="TxtStatus" Property="Text" Value="YES ✓"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Rerun">
                    <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource BrandAccent}"/>
                    <Setter TargetName="TxtStatus" Property="Text" Value="RERUN ↻"/>
                    <Setter TargetName="TxtStatus" Property="Foreground" Value="{StaticResource BrandPrimaryDark}"/>
                    <Setter TargetName="TxtMeta" Property="Foreground" Value="{StaticResource BrandPrimaryDark}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Empty">
                    <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource BtnWarning}"/>
                    <Setter TargetName="TxtStatus" Property="Text" Value="EMPTY ⚠"/>
                    <Setter TargetName="TxtStatus" Property="Foreground" Value="#FFFFFF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Skipped">
                    <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource TextSecondary}"/>
                    <Setter TargetName="TxtStatus" Property="Text" Value="SKIPPED"/>
                    <Setter TargetName="TxtMeta" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <FrameworkElement x:Name="VmProxy" DataContext="{Binding}" Visibility="Collapsed"/>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Command="{Binding ToggleStoreManagerCommand}" Content="⚙️ STORE CONFIG" Background="{StaticResource TextSecondary}" Foreground="#FFFFFF" FontWeight="Bold" Padding="15,8" VerticalAlignment="Top" Cursor="Hand" ToolTip="Manage the list of stores to scan"/>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Select Scan Mode" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton Content="📅 Daily Overview" IsChecked="{Binding IsModeDaily}" Style="{StaticResource SegmentedTab}"/>
                        <RadioButton Content="🏬 Store History" IsChecked="{Binding IsModeHistory}" Style="{StaticResource SegmentedTab}"/>
                        <RadioButton Content="🎯 Targeted Column" IsChecked="{Binding IsModeTargeted}" Style="{StaticResource SegmentedTab}"/>
                    </StackPanel>

                    <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15">
                        <Grid>
                            <StackPanel Visibility="{Binding IsModeDaily, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Scans all configured stores for their comprehensive status on a single specific date." Foreground="{StaticResource TextSecondary}" FontStyle="Italic" Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,25,0">
                                        <TextBlock Text="Target Date" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding TargetDate}" Width="180" Height="34" Padding="5"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsModeHistory, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Scans a single specific store across a range of dates to check consistency." Foreground="{StaticResource TextSecondary}" FontStyle="Italic" Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,25,0">
                                        <TextBlock Text="Select Target Store" Style="{StaticResource FormLabel}"/>
                                        <ComboBox ItemsSource="{Binding AvailableStores}" SelectedItem="{Binding SelectedHistoryStore}" DisplayMemberPath="StoreName" Width="200" Height="34" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,0">
                                        <TextBlock Text="Start Date" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding StartDate}" Width="150" Height="34" Padding="5"/>
                                    </StackPanel>
                                    <TextBlock Text="to" VerticalAlignment="Center" Margin="0,20,15,0" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                                    <StackPanel>
                                        <TextBlock Text="End Date" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding EndDate}" Width="150" Height="34" Padding="5"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsModeTargeted, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Scans a single specific file type (e.g., Promo, EJ) across ALL stores over a date range." Foreground="{StaticResource TextSecondary}" FontStyle="Italic" Margin="0,0,0,15"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,25,0">
                                        <TextBlock Text="Specific File / Log to Scan" Style="{StaticResource FormLabel}"/>
                                        <ComboBox ItemsSource="{Binding AvailableColumns}" SelectedItem="{Binding SelectedColumn}" Width="200" Height="34" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,0">
                                        <TextBlock Text="Start Date" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding StartDate}" Width="150" Height="34" Padding="5"/>
                                    </StackPanel>
                                    <TextBlock Text="to" VerticalAlignment="Center" Margin="0,20,15,0" Foreground="{StaticResource TextSecondary}" FontWeight="Bold"/>
                                    <StackPanel>
                                        <TextBlock Text="End Date" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding EndDate}" Width="150" Height="34" Padding="5"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrandPrimary}" FontWeight="Bold" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <ProgressBar Value="{Binding ScanProgress}" Height="8" Background="{StaticResource BorderLight}" Foreground="{StaticResource BrandPrimary}" BorderThickness="0" Maximum="100"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding ScanCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="🚀 START SCAN" Style="{StaticResource DangerButton}" Padding="35,12" FontSize="14"/>
            </Grid>

            <Border Grid.Row="3" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Background="{StaticResource BgCard}">
                <DataGrid ItemsSource="{Binding StoreResults}" AutoGenerateColumns="False" CanUserAddRows="False" 
                          HeadersVisibility="Column" Background="{StaticResource BgCard}" RowBackground="{StaticResource BgCard}" AlternatingRowBackground="{StaticResource BgApp}"
                          BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource BorderLight}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID / Date" Binding="{Binding DisplayId}" FontWeight="Bold" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Name / Day" Binding="{Binding DisplayName}" Width="180" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="EJ" Width="*" Visibility="{Binding DataContext.IsColEjVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding EjStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Pollog" Width="*" Visibility="{Binding DataContext.IsColPollogVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding PollogStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="CRM" Width="*" Visibility="{Binding DataContext.IsColCrmVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding CrmStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Promo" Width="*" Visibility="{Binding DataContext.IsColPromoVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding PromoStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="BIR" Width="*" Visibility="{Binding DataContext.IsColBirVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding BirStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="NonTrade" Width="*" Visibility="{Binding DataContext.IsColNonTradeVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding NonTradeStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="DOS Log" Width="*" Visibility="{Binding DataContext.IsColDosVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding DosStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Mob Prc" Width="*" Visibility="{Binding DataContext.IsColMobPriceVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding MobilePriceStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="PlusKu" Width="*" Visibility="{Binding DataContext.IsColPlusKuVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding PlusKuPriceStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Reg Prc" Width="*" Visibility="{Binding DataContext.IsColRegPriceVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding RegPriceStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="SIS98" Width="*" Visibility="{Binding DataContext.IsColSis98Visible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding Sis98Status}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ShelfT" Width="*" Visibility="{Binding DataContext.IsColShelftagVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding ShelftagStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Kiosk" Width="*" Visibility="{Binding DataContext.IsColKioskVisible, Source={x:Reference VmProxy}, Converter={StaticResource BoolToVis}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding KioskStatus}" ContentTemplate="{StaticResource StatusCellTemplate}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid Background="#CC000000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStoreManagerOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="{StaticResource BgCard}" Width="700" Height="600" CornerRadius="8" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Store Configuration Manager" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}"/>
                        <TextBlock Text="Add or remove stores from the SOD daily scanning rotation." FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,28,0,0"/>
                        <Button Command="{Binding ToggleStoreManagerCommand}" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" FontSize="18" Cursor="Hand" Foreground="{StaticResource TextSecondary}" Padding="5"/>
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource BgApp}" Padding="15" CornerRadius="6" Margin="0,0,0,20" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                        <WrapPanel VerticalAlignment="Center">
                            <StackPanel Margin="0,0,15,0" Width="80">
                                <TextBlock Text="Store Code" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding NewStore.StoreCode, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,0" Width="200">
                                <TextBlock Text="Store Name" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding NewStore.StoreName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,0" Width="100">
                                <TextBlock Text="POS System" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding NewStore.StoreType}"/>
                            </StackPanel>
                            <Button Command="{Binding AddStoreCommand}" Content="+ ADD STORE" Style="{StaticResource DangerButton}" Padding="20,8" VerticalAlignment="Bottom"/>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Background="{StaticResource BgCard}">
                        <DataGrid ItemsSource="{Binding AvailableStores}" AutoGenerateColumns="False" CanUserAddRows="False" 
                                  HeadersVisibility="Column" Background="{StaticResource BgCard}" RowBackground="{StaticResource BgCard}" AlternatingRowBackground="{StaticResource BgApp}"
                                  BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource BorderLight}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding StoreCode}" FontWeight="Bold" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Store Name" Binding="{Binding StoreName}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding StoreType}" Width="100" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Action" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="DELETE" Command="{Binding DataContext.DeleteStoreCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource DangerButton}" Padding="12,6"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>