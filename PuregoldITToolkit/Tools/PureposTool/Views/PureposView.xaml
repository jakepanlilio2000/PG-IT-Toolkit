<UserControl x:Class="PuregoldITToolkit.Tools.PureposTool.Views.PureposView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PuregoldITToolkit.Core.Converters">

    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SegmentedTab" TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource BgApp}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,0,8,0" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHighlight}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55*"/>
            <ColumnDefinition Width="45*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">
            <RadioButton x:Name="RbAutoPerm" Content="🔑 Auto Permission" IsChecked="True" Style="{StaticResource SegmentedTab}"/>
            <RadioButton x:Name="RbManualEj" Content="🗃️ Manual EJ Save" Style="{StaticResource SegmentedTab}"/>
            <RadioButton x:Name="RbCli" Content="💻 Remote CLI" Style="{StaticResource SegmentedTab}"/>
            <RadioButton x:Name="RbEod" Content="📧 EOD Generator" Style="{StaticResource SegmentedTab}"/>
        </StackPanel>

        <Grid Grid.Row="2" Grid.Column="0" Margin="0,0,20,0">

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding IsChecked, ElementName=RbAutoPerm, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Auto Permission Batch Execution" FontWeight="Bold" FontSize="16" Foreground="{StaticResource BrandPrimary}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource BtnSuccess}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right">
                            <TextBlock Text="🌐 Uses Global Live Server IP" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="Instantly triggers 'permission.sh' across all POS lanes and the CONSO server simultaneously to resolve local access issues." TextWrapping="Wrap" FontSize="12" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,20"/>

                    <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Configuration" FontWeight="Bold" Foreground="{StaticResource BrandPrimaryDark}" Margin="0,0,0,15" FontSize="13"/>
                            <StackPanel Width="150" HorizontalAlignment="Left">
                                <TextBlock Text="Total POS Lanes" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding PermissionData.TotalLanes}" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding RunPermissionCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="🚀 EXECUTE PARALLEL PERMISSIONS" Style="{StaticResource DangerButton}" Padding="20,15" HorizontalAlignment="Left" FontSize="14"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding IsChecked, ElementName=RbManualEj, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Manual EJ Synchronization" FontWeight="Bold" FontSize="16" Foreground="{StaticResource BrandPrimary}" VerticalAlignment="Center"/>
                            <Border Background="{StaticResource BtnSuccess}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right">
                                <TextBlock Text="🌐 Uses Global FTP &amp; SFTP IPs" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Detects missing EJ files on the Main FTP (.177) and securely bridges the missing archives from the local Conso server via SFTP." TextWrapping="Wrap" FontSize="12" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,20"/>

                        <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Scan Parameters" FontWeight="Bold" Foreground="{StaticResource BrandPrimaryDark}" Margin="0,0,0,15" FontSize="13"/>
                                <WrapPanel>
                                    <StackPanel Margin="0,0,20,15" Width="100">
                                        <TextBlock Text="Store Code" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EjData.StoreCode}" FontWeight="Bold" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,15" Width="150">
                                        <TextBlock Text="From Date" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding EjData.DateFrom}" Height="34" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Width="150" Margin="0,0,0,15">
                                        <TextBlock Text="To Date" Style="{StaticResource FormLabel}"/>
                                        <DatePicker SelectedDate="{Binding EjData.DateTo}" Height="34" Padding="5"/>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding RunEjSaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="🔍 SCAN &amp; SYNC EJ ARCHIVES" Background="{StaticResource BrandAccent}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold" Padding="25,15" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" FontSize="14"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding IsChecked, ElementName=RbCli, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="Remote Shell &amp; Batch Execution" FontWeight="Bold" FontSize="16" Foreground="{StaticResource BrandPrimary}" VerticalAlignment="Center"/>
                            <Border Background="{StaticResource BtnSuccess}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right">
                                <TextBlock Text="🔒 Uses Global POS Passwords" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Run scripts or raw SSH commands directly on POS lanes or Conso servers without needing manual Putty sessions." TextWrapping="Wrap" FontSize="12" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,20"/>

                        <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="1. Command &amp; Script Toolkit" FontWeight="Bold" Foreground="{StaticResource BrandPrimaryDark}" Margin="0,0,0,15" FontSize="13"/>

                                <TextBlock Text="Ready Scripts on CONSO (/opt/purepos/scripts/)" Style="{StaticResource FormLabel}"/>
                                <WrapPanel Margin="0,0,0,15">
                                    <ComboBox ItemsSource="{Binding AvailableScripts}" SelectedItem="{Binding SelectedScript}" Width="350" Height="34" Padding="5" Margin="0,0,10,0"/>
                                    <TextBlock Text="* Select to auto-fill." Foreground="{StaticResource TextSecondary}" FontStyle="Italic" VerticalAlignment="Center" FontSize="11"/>
                                </WrapPanel>

                                <TextBlock Text="Command to Execute" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding CliCommand}" Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="{StaticResource BgApp}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="2. Execution Targets" FontWeight="Bold" FontSize="14" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15"/>

                        <Border Background="{StaticResource BgApp}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="A. Specific Machine Target" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12" FontSize="13"/>
                                <WrapPanel Margin="0,0,0,15">
                                    <StackPanel Margin="0,0,15,0" Width="150">
                                        <TextBlock Text="Specific IP Address" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding CliTargetIp}"/>
                                    </StackPanel>
                                    <TextBlock Text="* Will execute using Global POS username and password." VerticalAlignment="Center" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,15,0,0"/>
                                </WrapPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding RunSingleCliCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="EXECUTE ON IP" Style="{StaticResource DangerButton}" Padding="15,10" Margin="0,0,10,0"/>
                                    <Button Command="{Binding OpenPuttyCommand}" Content="OPEN INTERACTIVE PUTTY" Style="{StaticResource SuccessButton}" Padding="15,10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource BgApp}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Padding="15">
                            <StackPanel>
                                <TextBlock Text="B. Batch Execution Targets" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5" FontSize="13"/>
                                <TextBlock Text="Automatically uses the IP Prefix and CONSO logic from Global Settings." FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,15"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding RunConsoCliCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="EXECUTE ON CONSO" Background="{StaticResource BrandAccent}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold" Padding="15,10" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                                    <Button Command="{Binding RunAllPosCliCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="EXECUTE ON ALL POS LANES" Background="{StaticResource BrandAccent}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold" Padding="15,10" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Style="{StaticResource CardStyle}" Visibility="{Binding IsChecked, ElementName=RbEod, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock Text="End-of-Day (EOD) Broadcaster" FontWeight="Bold" FontSize="16" Foreground="{StaticResource BrandPrimary}" VerticalAlignment="Center"/>
                            <Border Background="{StaticResource BtnSuccess}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right">
                                <TextBlock Text="🌐 Uses Global Live Server IP" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Automates the retrieval, compression, and distribution of daily POLLOG transaction files." TextWrapping="Wrap" FontSize="12" FontStyle="Italic" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,20"/>

                        <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="1. Store Identity &amp; Target" FontWeight="Bold" Foreground="{StaticResource BrandPrimaryDark}" Margin="0,0,0,15" FontSize="13"/>
                                <WrapPanel>
                                    <StackPanel Margin="0,0,20,12" Width="100">
                                        <TextBlock Text="Store Code" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EodData.StoreCode, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,12" Width="180">
                                        <TextBlock Text="Store Name" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EodData.StoreName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,20,12" Width="200">
                                        <TextBlock Text="Store Manager" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EodData.StoreManager, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12" Width="250">
                                        <TextBlock Text="Store Officers" Style="{StaticResource FormLabel}"/>
                                        <TextBox Text="{Binding EodData.StoreOfficer, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="2. Execution Toggles" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15" FontSize="14"/>
                        <WrapPanel Margin="0,0,0,20">
                            <CheckBox Content="Process YESTERDAY'S Date" IsChecked="{Binding EodData.UseYesterday}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Margin="0,0,20,0" ToolTip="Uses UTC+8 Date - 1"/>
                            <CheckBox Content="Test Mode (Send to Self)" IsChecked="{Binding EodData.TestModeEmail}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" Margin="0,0,20,0"/>
                            <CheckBox Content="Show Live Email Preview" IsChecked="{Binding EodData.EnableLivePreview}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                        </WrapPanel>

                        <Border Visibility="{Binding EodData.EnableLivePreview, Converter={StaticResource BoolToVis}}" Background="#F3F3F3" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Margin="0,0,0,25">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Live Email Details Preview" Background="{StaticResource BrandPrimary}" Foreground="#FFFFFF" FontWeight="Bold" Padding="12,6" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="1" Text="{Binding EodPreviewTo, StringFormat='To: {0}'}" Foreground="#666666" FontWeight="SemiBold" Padding="12,0" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Text="{Binding EodPreviewCc, StringFormat='Cc: {0}'}" Foreground="#666666" FontWeight="SemiBold" Padding="12,4" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Text="{Binding EodPreviewSubject, StringFormat='Subject: {0}'}" Foreground="#000000" FontWeight="Bold" Padding="12,0" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4" Text="{Binding EodPreviewAttachment}" Foreground="#00529B" FontWeight="SemiBold" Padding="12,8" Margin="0,0,0,5"/>
                                <TextBox Grid.Row="5" Text="{Binding EodPreviewBody, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Background="#FFFFFF" Foreground="#000000" FontFamily="Calibri, Arial" FontSize="14" Padding="12" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0"/>
                            </Grid>
                        </Border>

                        <Button Command="{Binding RunEodCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="📧 EXECUTE EOD GENERATOR" Style="{StaticResource DangerButton}" Padding="20,15" HorizontalAlignment="Left" FontSize="14"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.Column="1" Background="#2C3E50" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Terminal Logs" Foreground="{StaticResource BrandAccent}" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                    <Button Command="{Binding ClearLogCommand}" Content="CLEAR" HorizontalAlignment="Right" Style="{StaticResource DangerButton}" Padding="12,4" FontSize="11" Cursor="Hand"/>
                </Grid>

                <TextBox Grid.Row="1" Text="{Binding CliOutput, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#1A252F" Foreground="#2ECC71" FontFamily="Consolas" FontSize="12" Padding="12" BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>