<UserControl x:Class="PuregoldITToolkit.Tools.PureposTool.Views.PureposView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PuregoldITToolkit.Core.Converters">

    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>
        <TabControl Grid.Row="1" Grid.Column="0" Margin="0,0,20,0" Background="Transparent" BorderThickness="0">
            <TabItem Header="Auto Permission.sh" FontWeight="Bold">
                <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="Network Config" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15" FontSize="14"/>
                        <WrapPanel Margin="0,0,0,20">
                            <StackPanel Margin="0,0,20,0" Width="160">
                                <TextBlock Text="Live Server IP" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding PermissionData.LiveServerIp}"/>
                            </StackPanel>
                            <StackPanel Width="110">
                                <TextBlock Text="Total POS Lanes" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding PermissionData.TotalLanes}"/>
                            </StackPanel>
                        </WrapPanel>

                        <TextBlock Text="CONSO Credentials" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,15,0,15" FontSize="14"/>
                        <WrapPanel Margin="0,0,0,25">
                            <StackPanel Margin="0,0,20,0" Width="160">
                                <TextBlock Text="Username" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding PermissionData.ConsoUser}"/>
                            </StackPanel>
                            <StackPanel Width="160">
                                <TextBlock Text="Password" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding PermissionData.ConsoPassword}"/>
                            </StackPanel>
                        </WrapPanel>

                        <Button Command="{Binding RunPermissionCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="EXECUTE PERMISSIONS" Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Manual EJ Save" FontWeight="Bold" Width="200">
                <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Store &amp; Network" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15" FontSize="14"/>
                            <WrapPanel Margin="0,0,0,20">
                                <StackPanel Margin="0,0,20,0" Width="90">
                                    <TextBlock Text="Store Code" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EjData.StoreCode}" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,20,0" Width="130">
                                    <TextBlock Text="Live Server IP" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EjData.LiveServerIp}"/>
                                </StackPanel>
                                <StackPanel Width="130">
                                    <TextBlock Text="FTP Server" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EjData.FtpServer}"/>
                                </StackPanel>
                            </WrapPanel>

                            <TextBlock Text="Date Range" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,10,0,15" FontSize="14"/>
                            <WrapPanel Margin="0,0,0,20">
                                <StackPanel Margin="0,0,20,0" Width="160">
                                    <TextBlock Text="From Date" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <DatePicker SelectedDate="{Binding EjData.DateFrom}" Height="34" Padding="5"/>
                                </StackPanel>
                                <StackPanel Width="160">
                                    <TextBlock Text="To Date" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <DatePicker SelectedDate="{Binding EjData.DateTo}" Height="34" Padding="5"/>
                                </StackPanel>
                            </WrapPanel>

                            <TextBlock Text="CONSO Credentials" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,10,0,15" FontSize="14"/>
                            <WrapPanel Margin="0,0,0,25">
                                <StackPanel Margin="0,0,20,0" Width="160">
                                    <TextBlock Text="Username" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EjData.ConsoUser}"/>
                                </StackPanel>
                                <StackPanel Width="160">
                                    <TextBlock Text="Password" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding EjData.ConsoPassword}"/>
                                </StackPanel>
                            </WrapPanel>

                            <Button Command="{Binding RunEjSaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="SCAN &amp; SYNC EJ ARCHIVES" Background="{StaticResource BrandAccent}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold" Padding="20,12" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Grid.Column="1" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,32,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Execution Logs" Foreground="{StaticResource BrandAccent}" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                    <Button Command="{Binding ClearLogCommand}" Content="CLEAR" HorizontalAlignment="Right" Style="{StaticResource DangerButton}" Padding="12,4" FontSize="11"/>
                </Grid>

                <TextBox Grid.Row="1" Text="{Binding CliOutput, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#1A252F" Foreground="#2ECC71" FontFamily="Consolas" FontSize="12" Padding="12" BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>