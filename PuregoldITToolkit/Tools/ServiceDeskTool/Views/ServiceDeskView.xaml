<UserControl x:Class="PuregoldITToolkit.Tools.ServiceDeskTool.Views.ServiceDeskView"
             xmlns:converters="clr-namespace:PuregoldITToolkit.Core.Converters"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <TabItem Header="OT Report Generator" FontWeight="Bold" Width="300">
                <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" Margin="0,0,0,20">
                            <StackPanel Margin="0,0,25,0">
                                <TextBlock Text="Cutoff Start Date" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding CutoffStart}" Width="160" Height="34" Padding="5"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Cutoff End Date" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                <DatePicker SelectedDate="{Binding CutoffEnd}" Width="160" Height="34" Padding="5"/>
                            </StackPanel>
                        </WrapPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Overtime Monitoring Data" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" VerticalAlignment="Center" Margin="0,0,20,0" FontSize="14"/>
                            <Button Command="{Binding AddOtRowCommand}" Content="+ ADD ROW" Background="{StaticResource BrandAccent}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>

                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="6" Background="{StaticResource BgCard}">
                            <DataGrid ItemsSource="{Binding OtEntries}" AutoGenerateColumns="False" CanUserAddRows="False" 
                                      Background="{StaticResource BgCard}" RowBackground="{StaticResource BgCard}" AlternatingRowBackground="{StaticResource BgApp}" 
                                      BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource BorderLight}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="EMPLOYEE" Binding="{Binding Employee, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                                    <DataGridTextColumn Header="STORE" Binding="{Binding Store, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                    <DataGridTemplateColumn Header="DATE OF OVERTIME" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <DatePicker SelectedDate="{Binding DateOfOvertime, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="HOURS" Binding="{Binding Hours, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                    <DataGridTextColumn Header="MINS" Binding="{Binding Minutes, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                    <DataGridTextColumn Header="PURPOSE" Binding="{Binding Purpose, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                    <DataGridTextColumn Header="PRE-APPROVED BY" Binding="{Binding PreApprovedBy, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Broadband Outage Drafter" FontWeight="Bold" Width="300">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,10,15,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel HorizontalAlignment="Left">

                                <Border Background="{StaticResource BgHighlight}" BorderBrush="{StaticResource BorderFocus}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                            <TextBlock Text="Load Store Profile" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,8" FontSize="14"/>
                                            <ComboBox ItemsSource="{Binding StoreProfiles}" SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="DisplayName" Height="34" Padding="5"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <Button Command="{Binding SaveProfileCommand}" Content="SAVE / UPDATE" Style="{StaticResource SuccessButton}" Padding="15,8" Margin="0,0,8,0" ToolTip="Saves the form data below permanently to the active Store Code."/>
                                            <Button Command="{Binding DeleteProfileCommand}" Content="DELETE" Style="{StaticResource DangerButton}" Padding="15,8" Margin="0,0,8,0"/>
                                            <Button Command="{Binding ClearOutageFormCommand}" Content="CLEAR" Background="{StaticResource TextSecondary}" Foreground="#FFFFFF" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <TextBlock Text="Outage Core Details" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,12" FontSize="14"/>
                                <WrapPanel Margin="0,0,0,20">
                                    <StackPanel Margin="0,0,15,12" Width="110">
                                        <TextBlock Text="ISP *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <ComboBox SelectedValue="{Binding OutageData.Isp}" SelectedValuePath="Content" Height="34" Padding="5">
                                            <ComboBoxItem Content="GLOBE" IsSelected="True"/>
                                            <ComboBoxItem Content="CONVERGE"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,12" Width="110">
                                        <TextBlock Text="Store Code *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.StoreCode, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,12" Width="190">
                                        <TextBlock Text="Store Name *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.StoreName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12" Width="260">
                                        <TextBlock Text="Default IT-ZONE CC" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.AllItZoneEmail, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                </WrapPanel>

                                <TextBlock Text="Modem &amp; Issue Details" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,10,0,12" FontSize="14"/>
                                <WrapPanel Margin="0,0,0,20">
                                    <StackPanel Margin="0,0,15,12" Width="210">
                                        <TextBlock Text="Modem Serial *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.ModemSerial, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,12" Width="160">
                                        <TextBlock Text="CID / SID" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.CidSid, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12" Width="160">
                                        <TextBlock Text="Status *" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <ComboBox SelectedValue="{Binding OutageData.IssueStatus}" SelectedValuePath="Content" Height="34" Padding="5">
                                            <ComboBoxItem Content="DOWN" IsSelected="True"/>
                                            <ComboBoxItem Content="INTERMITTENT"/>
                                        </ComboBox>
                                    </StackPanel>
                                </WrapPanel>

                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Issue Description (Press Enter for new line)" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding OutageData.IssueDesc, UpdateSourceTrigger=PropertyChanged}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>

                                <WrapPanel Margin="0,0,0,25" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="Picture of Modem" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <Button Command="{Binding BrowseAttachmentCommand}" Content="Browse Image..." Background="{StaticResource BrandAccent}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold" BorderThickness="0" Padding="15,8" Cursor="Hand"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding OutageData.AttachmentPath, StringFormat='Attached: {0}'}" VerticalAlignment="Bottom" Margin="0,0,0,8" FontSize="11" Foreground="{StaticResource BtnSuccess}" FontStyle="Italic" TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                                </WrapPanel>

                                <TextBlock Text="Site Contact Info" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,10,0,12" FontSize="14"/>
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Exact Address" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding OutageData.Address, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <WrapPanel Margin="0,0,0,20">
                                    <StackPanel Margin="0,0,15,12" Width="210">
                                        <TextBlock Text="Contact Person / Number" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.ContactPerson, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,15,12" Width="160">
                                        <TextBlock Text="Availability" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.Availability, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12" Width="210">
                                        <TextBlock Text="Access Pass Needed?" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.AccessPass, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WrapPanel>

                                <TextBlock Text="Zone Head Routing" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,10,0,12" FontSize="14"/>
                                <WrapPanel Margin="0,0,0,25">
                                    <StackPanel Margin="0,0,20,12" Width="260">
                                        <TextBlock Text="Zone Head Name" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.ZoneHeadName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,12" Width="260">
                                        <TextBlock Text="Zone Head Email" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding OutageData.ZoneHeadEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Live Email Preview" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,12"/>
                            <TextBox Grid.Row="1" Text="{Binding OutageData.GeneratedBody, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#FFFFFF" Foreground="{StaticResource TextPrimary}" FontFamily="Consolas" FontSize="13" Padding="12" BorderBrush="{StaticResource BorderLight}" BorderThickness="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrandPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding ExportOtCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="GENERATE OT EXCEL" Style="{StaticResource DangerButton}" Margin="0,0,12,0" Padding="25,12"/>
                <Button Command="{Binding DraftEmailCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Content="DRAFT OUTAGE EMAIL" Background="{StaticResource BrandAccent}" Foreground="{StaticResource BrandPrimaryDark}" FontWeight="Bold" Padding="25,12" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>