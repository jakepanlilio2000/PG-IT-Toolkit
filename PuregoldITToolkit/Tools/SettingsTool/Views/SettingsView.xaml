<UserControl x:Class="PuregoldITToolkit.Tools.SettingsTool.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
            <StackPanel>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="PIMS Database Configuration" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15" FontSize="14"/>
                        <WrapPanel Margin="0,0,0,15">
                            <StackPanel Margin="0,0,15,12" Width="180">
                                <TextBlock Text="SQL Server IP" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.PimsSqlServer, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="150">
                                <TextBlock Text="Database Name" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.PimsSqlDatabase, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,10">
                            <StackPanel Margin="0,0,15,12" Width="180">
                                <TextBlock Text="SQL Username" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.PimsSqlUsername, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="180">
                                <TextBlock Text="SQL Password" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.PimsSqlPassword, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="PurePOS Network &amp; CONSO Credentials" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15" FontSize="14"/>
                        <WrapPanel Margin="0,0,0,15">
                            <StackPanel Margin="0,0,15,12" Width="180">
                                <TextBlock Text="CONSO / SFTP Username" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.ConsoUser, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="180">
                                <TextBlock Text="CONSO / SFTP Password" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.ConsoPassword, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="100">
                                <TextBlock Text="Store Code" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.DefaultStoreCode, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold"/>
                            </StackPanel>
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,10">
                            <StackPanel Margin="0,0,15,12" Width="180">
                                <TextBlock Text="Default Live Server IP" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.DefaultLiveServerIp, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="180">
                                <TextBlock Text="Default FTP Server IP" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.DefaultFtpServer, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="SMTP Network &amp; Mailing Configuration" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,15" FontSize="14"/>
                        <WrapPanel Margin="0,0,0,15">
                            <StackPanel Margin="0,0,15,12" Width="180">
                                <TextBlock Text="SMTP Server IP" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.SmtpServer, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="80">
                                <TextBlock Text="SMTP Port" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.SmtpPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="250">
                                <TextBlock Text="Sender Identity Name" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.SenderName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </WrapPanel>
                        <WrapPanel Margin="0,0,0,15">
                            <StackPanel Margin="0,0,15,12" Width="220">
                                <TextBlock Text="SMTP Email Address" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.SmtpUser, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,15,12" Width="220">
                                <TextBlock Text="SMTP Password" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding SettingsData.SmtpPass, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </WrapPanel>
                        <StackPanel Margin="0,0,15,12">
                            <TextBlock Text="Thunderbird Local Sent Box Path (MBOX)" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding SettingsData.ThunderbirdSentPath, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Global HTML Signature" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,5" FontSize="14"/>
                        <TextBlock Text="Paste your raw HTML signature below. This will be automatically injected into outgoing emails." 
                                   Foreground="{StaticResource TextSecondary}" Margin="0,0,0,15" TextWrapping="Wrap"/>

                        <TextBox Text="{Binding SettingsData.SignatureHtml, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="200" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                                 FontFamily="Consolas" FontSize="13" Background="{StaticResource BgApp}" Padding="12"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Command="{Binding SaveSettingsCommand}" Content="SAVE GLOBAL CONFIGURATIONS" Style="{StaticResource SuccessButton}" Padding="25,15" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrandPrimary}" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>