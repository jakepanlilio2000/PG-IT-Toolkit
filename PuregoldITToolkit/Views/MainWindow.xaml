<Window x:Class="PuregoldITToolkit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        
        xmlns:ejVm="clr-namespace:PuregoldITToolkit.Tools.EJConsolidator.ViewModels"
        xmlns:ejV="clr-namespace:PuregoldITToolkit.Tools.EJConsolidator.Views"
        
        xmlns:sodVm="clr-namespace:PuregoldITToolkit.Tools.SodChecker.ViewModels"
        xmlns:sodV="clr-namespace:PuregoldITToolkit.Tools.SodChecker.Views"
        
        xmlns:formsVm="clr-namespace:PuregoldITToolkit.Tools.FormsTool.ViewModels"
        xmlns:formsV="clr-namespace:PuregoldITToolkit.Tools.FormsTool.Views"
        
        mc:Ignorable="d"
        Title="Puregold IT Toolkit | Enterprise Shell" 
        Height="700" Width="1024" 
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Window.Resources>
        <!-- EJ Consolidator Mapping -->
        <DataTemplate DataType="{x:Type ejVm:EJConsolidatorViewModel}">
            <ejV:EJConsolidatorView />
        </DataTemplate>

        <!-- SOD Checker Mapping -->
        <DataTemplate DataType="{x:Type sodVm:SodCheckerViewModel}">
            <sodV:SodCheckerView />
        </DataTemplate>

        <!-- Forms Tool Mapping -->
        <DataTemplate DataType="{x:Type formsVm:FormsMainViewModel}">
            <formsV:FormsMainView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E272E" Padding="0,20,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,0,20,30">
                    <TextBlock Text="PUREGOLD" Foreground="#E1B12C" FontSize="26" FontWeight="Black" HorizontalAlignment="Center" />
                    <TextBlock Text="IT STORE TOOLKIT" Foreground="#7F8FA6" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding AvailableTools}" 
                         SelectedItem="{Binding SelectedTool, Mode=TwoWay}"
                         Background="Transparent" 
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10,0">
                                <TextBlock Text="{Binding ToolName}" Foreground="White" FontSize="15" FontWeight="Medium"/>
                                <TextBlock Text="{Binding Description}" Foreground="#7F8FA6" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="Margin" Value="10,4"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="MenuBorder" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="6">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="MenuBorder" Property="Background" Value="#2F3640"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="MenuBorder" Property="Background" Value="#0097E6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" Margin="15" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#ECDFE6" BorderThickness="0,0,0,1" Padding="20">
                    <TextBlock Text="{Binding SelectedTool.ToolName}" FontSize="24" FontWeight="Light" Foreground="#2F3640"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="20">
                    <ContentControl Content="{Binding SelectedTool.ToolViewModel}" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>