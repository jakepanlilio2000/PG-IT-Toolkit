<Window x:Class="PuregoldITToolkit.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Puregold IT Toolkit" 
        Height="768" Width="1366" 
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgApp}"
        WindowState="Maximized"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style x:Key="TopBarMenuItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="6" VerticalAlignment="Center">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource BrandAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarTextPrimary" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BrandPrimaryDark}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource BrandPrimaryDark}" Padding="30,15">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="PUREGOLD" Foreground="{StaticResource BrandAccent}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="IT TOOLKIT" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Opacity="0.9"/>
                    </StackPanel>
                </Border>

                <ListBox Grid.Column="1" 
                         ItemsSource="{Binding AvailableTools}" 
                         SelectedItem="{Binding SelectedTool, Mode=TwoWay}"
                         Background="Transparent" 
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource TopBarMenuItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         Padding="15,0"
                         VerticalAlignment="Stretch">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ToolName}" Style="{StaticResource TopBarTextPrimary}" TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource BgApp}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <Border Grid.Row="1" Padding="15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ContentControl Content="{Binding SelectedTool.ToolViewModel}" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,1,0,0" Padding="15,8">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="12">
                <Run Text="Developed by "/>
                <Run Text="Jake Panlilio" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}"/>
                <Run Text=" — IT SF1 for Zone 11"/>
            </TextBlock>
        </Border>
    </Grid>
</Window>